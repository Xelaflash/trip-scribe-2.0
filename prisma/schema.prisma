generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String    @unique
  role          Role      @default(USER)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  trips         Trip[]
}

model Trip {
  id             String          @id @default(uuid())
  title          String
  description    String?
  visibility     Visibility      @default(PRIVATE)
  destinations   String[]
  slug           String          @unique
  userId         String
  startDate      DateTime
  endDate        DateTime
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  itineraryItems ItineraryItem[]
  notes          TripNote[]
  places         TripPlace[]
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([visibility])
}

model ItineraryItem {
  id          String    @id @default(uuid())
  tripId      String
  title       String
  description String?
  location    String?
  startsAt    DateTime?
  endsAt      DateTime?
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([id, tripId])
  @@index([tripId, startsAt])
}

model TripNote {
  id        String   @id @default(uuid())
  tripId    String
  title     String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([id, tripId])
  @@index([tripId, updatedAt])
}

model TripPlace {
  id        String   @id @default(uuid())
  tripId    String
  name      String
  category  String?
  address   String?
  url       String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([id, tripId])
  @@index([tripId, name])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum Visibility {
  PRIVATE
  PUBLIC
}
